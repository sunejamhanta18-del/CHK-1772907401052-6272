<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8F5E9"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/top_branding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="start"
        android:layout_alignParentTop="true">
        <ImageView
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:src="@drawable/logo"
            android:scaleType="centerInside"
            android:layout_marginBottom="12dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AgriPulse"
            android:textColor="#1B5E20"
            android:textStyle="bold"
            android:textSize="24sp" />
    </LinearLayout>

    <RelativeLayout
        android:id="@+id/bottom_profile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="20dp"
        android:background="#F8F8F8"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/profile_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_manage"
            android:layout_centerVertical="true"
            app:tint="#1B5E20" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_toEndOf="@id/profile_icon"
            android:layout_marginStart="15dp"
            android:layout_centerVertical="true">
            <TextView
                android:id="@+id/nav_farmer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Namaste, Farmer"
                android:textColor="#333333"
                android:textStyle="bold"
                android:textSize="16sp" />
            <TextView
                android:id="@+id/nav_farm_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AgriPulse Monitor Active"
                android:textColor="#666666"
                android:textSize="12sp" />
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>