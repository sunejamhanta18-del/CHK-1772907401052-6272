<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F0"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvTimeStat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Last Sync: 10:00 AM"
        android:textColor="#666666"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Live Sensor Data"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1B5E20"
        android:layout_marginBottom="20dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        android:layout_marginBottom="12dp">
        <LinearLayout android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Temperature" android:textStyle="bold"/>
            <TextView android:id="@+id/tvTempStat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="#4CAF50" android:textStyle="bold"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        android:layout_marginBottom="12dp">
        <LinearLayout android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Humidity" android:textStyle="bold"/>
            <TextView android:id="@+id/tvHumStat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="#2196F3" android:textStyle="bold"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        android:layout_marginBottom="12dp">
        <LinearLayout android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Ammonia Gas" android:textStyle="bold"/>
            <TextView android:id="@+id/tvGasStat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="#FF9800" android:textStyle="bold"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>