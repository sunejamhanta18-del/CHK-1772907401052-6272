<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F0"
    android:padding="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Namaste, Farmer"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1B5E20" />
        <ImageButton
            android:id="@+id/btnProfile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_manage"
            app:tint="#1B5E20" />
    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="#1B5E20">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/mainTemp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="28°C"
                android:textColor="#FFFFFF"
                android:textSize="50sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/mainHum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Humidity: 62%"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Shelf Monitoring Map"
        android:layout_marginTop="25dp"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#333333" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="3"
        android:layout_marginTop="10dp">
        <Button android:id="@+id/shelf1" android:layout_width="0dp" android:layout_height="100dp" android:layout_columnWeight="1" android:layout_margin="5dp" android:text="Shelf 1" android:backgroundTint="#4CAF50" />
        <Button android:id="@+id/shelf2" android:layout_width="0dp" android:layout_height="100dp" android:layout_columnWeight="1" android:layout_margin="5dp" android:text="Shelf 2" android:backgroundTint="#F44336" />
        <Button android:id="@+id/shelf3" android:layout_width="0dp" android:layout_height="100dp" android:layout_columnWeight="1" android:layout_margin="5dp" android:text="Shelf 3" android:backgroundTint="#4CAF50" />
        <Button android:id="@+id/shelf4" android:layout_width="0dp" android:layout_height="100dp" android:layout_columnWeight="1" android:layout_margin="5dp" android:text="Shelf 4" android:backgroundTint="#FFC107" />
        <Button android:id="@+id/shelf5" android:layout_width="0dp" android:layout_height="100dp" android:layout_columnWeight="1" android:layout_margin="5dp" android:text="Shelf 5" android:backgroundTint="#4CAF50" />
        <Button android:id="@+id/shelf6" android:layout_width="0dp" android:layout_height="100dp" android:layout_columnWeight="1" android:layout_margin="5dp" android:text="Shelf 6" android:backgroundTint="#4CAF50" />
    </GridLayout>
</LinearLayout>